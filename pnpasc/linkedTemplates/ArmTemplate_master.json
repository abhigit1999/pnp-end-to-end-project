{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "pnpasc"
		},
		"LS_brozen_to_silver_dbn_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'LS_brozen_to_silver_dbn'"
		},
		"LS_pnpbyedge_bronze_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_pnpbyedge_bronze'"
		},
		"LS_ascentail_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 'LS_ascentail'"
		},
		"LS_brozen_to_silver_dbn_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0603-054526-nhn8s142"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "pnpasc_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_brozen_to_silver_dbn_accessToken": {
						"value": "[parameters('LS_brozen_to_silver_dbn_accessToken')]"
					},
					"LS_pnpbyedge_bronze_connectionString": {
						"value": "[parameters('LS_pnpbyedge_bronze_connectionString')]"
					},
					"LS_ascentail_sasUri": {
						"value": "[parameters('LS_ascentail_sasUri')]"
					},
					"LS_brozen_to_silver_dbn_properties_typeProperties_existingClusterId": {
						"value": "[parameters('LS_brozen_to_silver_dbn_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}